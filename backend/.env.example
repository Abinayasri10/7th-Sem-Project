# Flask config
PORT=5000
FLASK_ENV=development

# Google Earth Engine Service Account key path
# Place your key JSON in backend/gee_credentials.json (ignored by git) and set this variable
GEE_PRIVATE_KEY_PATH=gee_credentials.json

# Deep Learning model paths
MODEL_PATH=ml/models/crop_disease_model.keras
CLASS_NAMES_PATH=ml/class_names.json

# CORS allowed origins (comma separated if multiple)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
